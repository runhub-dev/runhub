{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "apps": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "format": "hostname",
        "pattern": "^[a-z0-9]*$",
        "minLength": 1
      },
      "not": {
        "required": ["runhub"]
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "repository": {
            "type": "string",
            "minLength": 1
          },
          "revision": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": ["repository", "revision"],
        "additionalProperties": false
      }
    },
    "runhub": {
      "type": "object",
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "revision": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": ["repository", "revision"],
      "additionalProperties": false
    }
  },
  "required": ["runhub"],
  "additionalProperties": false
}
