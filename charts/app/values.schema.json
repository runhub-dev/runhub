{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "name": {},
    "app": {},
    "services": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "format": "hostname",
        "pattern": "^[a-z0-9]*$",
        "minLength": 1,
        "maxLength": 63
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "image": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": ["image"],
        "additionalProperties": false
      }
    },
    "runhub": {}
  },
  "required": ["name", "app", "services", "runhub"],
  "additionalProperties": false
}
