{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "runhub": {
      "type": "object",
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "revision": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": ["repository", "revision"],
      "additionalProperties": false
    },
    "repository": {
      "type": "string",
      "minLength": 1
    },
    "revision": {
      "type": "string",
      "minLength": 1
    },
    "services": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "format": "hostname",
        "pattern": "^[a-z0-9-]*$",
        "minLength": 1,
        "maxLength": 63
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "image": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": ["image"],
        "additionalProperties": false
      }
    }
  },
  "required": ["runhub", "repository", "revision", "services"],
  "additionalProperties": false
}
